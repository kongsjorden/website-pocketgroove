---
import Layout from '../layouts/Layout.astro';
import PhoneMockup from '../components/PhoneMockup.astro';

const features = [
  {
    title: 'Circular Clock Visualization',
    description: 'Watch your taps appear as dots on a clock face. Each beat is a position around the circle, giving you an intuitive picture of where your timing lands relative to the beat.',
    icon: 'clock',
    details: ['Visual clock face display', 'Tap dots around the circle', 'Beat position markers', 'Early/late color coding'],
  },
  {
    title: '28 Progressive Levels',
    description: 'Five training phases take you from basic quarter notes to complex syncopated patterns. Each level builds on the last, creating a natural learning curve.',
    icon: 'levels',
    details: ['Phase 1: Foundation (quarter notes)', 'Phase 2: Subdivision (eighth notes)', 'Phase 3: Syncopation (offbeats)', 'Phase 4: Complex (mixed patterns)', 'Phase 5: Mastery (advanced rhythms)'],
  },
  {
    title: 'Real-Time Timing Feedback',
    description: 'Every tap is measured in milliseconds. See exactly how early or late you are, with color-coded indicators showing your precision level.',
    icon: 'precision',
    details: ['Millisecond accuracy', 'Color-coded feedback', 'Average deviation tracking', 'Per-tap timing display'],
  },
  {
    title: '3-Star Rating System',
    description: 'Earn up to 3 stars on each level based on your timing accuracy. Stars drive progression and unlock new content as you improve.',
    icon: 'star',
    details: ['Accuracy-based star rating', 'Unlocks progression', 'Personal best tracking', 'Replay to improve score'],
  },
  {
    title: 'Game Modes',
    description: 'Three distinct modes keep training fresh. Practice mode for learning at your own pace, Survival for endurance, and Speed Challenge to push your limits.',
    icon: 'gamepad',
    details: ['Practice: learn without pressure', 'Survival: miss and it\'s over', 'Speed Challenge: tempo ramps up', 'Each mode has unique strategy'],
  },
  {
    title: 'Pocket Profile',
    description: 'Your personal groove analysis dashboard. See patterns in your timing — do you tend to rush or drag? Which subdivisions challenge you most?',
    icon: 'profile',
    details: ['Rush/drag tendency analysis', 'Subdivision breakdown', 'Progress over time', 'Strengths and weaknesses'],
  },
  {
    title: 'Feel Training',
    description: 'Go beyond the grid. Practice laying back for neo-soul feel, pushing ahead for funk urgency, or finding the reggae pocket. Train the subtle art of groove.',
    icon: 'feel',
    details: ['Funk push feel', 'Neo-soul laid-back feel', 'Reggae one-drop pocket', 'Adjustable feel intensity'],
  },
  {
    title: 'Badges & Achievements',
    description: '17 unique badges reward your journey. From "First Steps" to mastery achievements, badges celebrate milestones and keep you motivated.',
    icon: 'badge',
    details: ['17 unique badges', 'Milestone rewards', 'Skill-based unlocks', 'Progress celebration'],
  },
];

const iconPaths: Record<string, string> = {
  clock: `<circle cx="12" cy="12" r="9" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M12 7v5l3 3"/><circle cx="12" cy="12" r="1" fill="currentColor"/>`,
  levels: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
  precision: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  star: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>`,
  gamepad: `<rect x="2" y="6" width="20" height="12" rx="2" stroke-width="2"/><line x1="6" y1="10" x2="6" y2="14" stroke-width="2" stroke-linecap="round"/><line x1="4" y1="12" x2="8" y2="12" stroke-width="2" stroke-linecap="round"/><circle cx="16" cy="10" r="1" fill="currentColor"/><circle cx="19" cy="12" r="1" fill="currentColor"/>`,
  profile: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>`,
  feel: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>`,
  badge: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>`,
};
---

<Layout title="Features" description="Explore all the features of PocketGroove - rhythm training with circular visualization, progressive levels, and multiple game modes.">
  <!-- Header -->
  <section class="pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h1 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl text-text mb-6">
        Powerful Features
      </h1>
      <p class="text-text-muted text-lg md:text-xl max-w-2xl mx-auto">
        Everything you need to develop rock-solid timing and an unshakeable internal clock.
      </p>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="group p-6 bg-surface rounded-2xl border border-border hover:border-primary/50 transition-all duration-300 hover:shadow-xl hover:shadow-primary/5">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5 group-hover:bg-primary/20 transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconPaths[feature.icon]} />
            </div>

            <!-- Content -->
            <h3 class="font-display font-semibold text-xl text-text mb-3">
              {feature.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              {feature.description}
            </p>

            <!-- Details -->
            <ul class="space-y-2">
              {feature.details.map(detail => (
                <li class="flex items-center gap-2 text-text-dim text-sm">
                  <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Screenshots Section -->
  <section class="py-20 bg-background-light/50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="font-display font-bold text-3xl md:text-4xl text-text text-center mb-4">
        See It in Action
      </h2>
      <p class="text-text-muted text-center mb-12 max-w-2xl mx-auto">
        A clean, focused interface designed for distraction-free rhythm training
      </p>

      <!-- Main showcase - 3 phones -->
      <div class="flex justify-center items-end gap-4 md:gap-8 mb-12">
        <div class="hidden sm:block relative -rotate-6 translate-y-8">
          <div class="absolute inset-0 bg-primary/10 rounded-[3rem] blur-2xl opacity-50"></div>
          <PhoneMockup src="/screenshots/01-levels.png" alt="Levels" size="sm" />
        </div>
        <div class="relative z-10">
          <div class="absolute -inset-8 bg-primary/20 rounded-[4rem] blur-3xl"></div>
          <PhoneMockup src="/screenshots/02-play.png" alt="Play mode" size="lg" />
        </div>
        <div class="hidden sm:block relative rotate-6 translate-y-8">
          <div class="absolute inset-0 bg-primary/10 rounded-[3rem] blur-2xl opacity-50"></div>
          <PhoneMockup src="/screenshots/03-results.png" alt="Results" size="sm" />
        </div>
      </div>

      <!-- Thumbnail row -->
      <div class="flex justify-center gap-4 flex-wrap">
        {[
          { src: '/screenshots/04-level-detail.png', label: 'Level Detail' },
          { src: '/screenshots/05-advanced-notation.png', label: 'Notation' },
          { src: '/screenshots/06-pocket-profile.png', label: 'Pocket Profile' },
        ].map(item => (
          <div class="group cursor-pointer">
            <div class="w-20 h-36 md:w-24 md:h-44 rounded-2xl overflow-hidden border-2 border-border/50 group-hover:border-primary/50 transition-all duration-300 shadow-lg group-hover:shadow-primary/20">
              <img
                src={item.src}
                alt={item.label}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <p class="text-center text-text-dim text-xs mt-2 group-hover:text-primary transition-colors">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="font-display font-bold text-3xl md:text-4xl text-text mb-4">
        Ready to Get Started?
      </h2>
      <p class="text-text-muted text-lg mb-8 max-w-xl mx-auto">
        PocketGroove is launching soon. Start training your internal clock.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <span
          class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-primary/50 text-white/70 font-semibold rounded-xl cursor-default"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          Coming Soon on App Store
        </span>
        <a
          href="/faq"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-surface hover:bg-surface-hover text-text font-semibold rounded-xl border border-border transition-colors"
        >
          Read the FAQ
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .font-display {
    font-family: 'Outfit', sans-serif;
  }
</style>
